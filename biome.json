{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "ignoreUnknown": true, "includes": ["**", "!**/node_modules", "!**/dist", "!**/coverage"] },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true, "style": { "useImportType": { "level": "error", "fix": "safe" } } }
  },
  "formatter": { "enabled": true, "lineWidth": 120, "indentStyle": "space", "indentWidth": 2, "expand": "never" },
  "javascript": { "formatter": { "quoteStyle": "single" } },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": { "groups": [":NODE:", ":BLANK_LINE:", ":PACKAGE:", ":BLANK_LINE:", ":PATH:"] }
        }
      }
    }
  }
}
